# --- Acumatica connection ---
ACU_URL=https://tenant.acumatica.com
ACU_ENDPOINT=Default/24.200.001

# --- OAuth for the WEB UI (Authorization Code + PKCE) ---
# Register a Connected Application in Acumatica (SM303010) for "Authorization Code".
# Redirect URI must match exactly what you set on the Connected App.
ACU_CLIENT_ID=
ACU_CLIENT_SECRET=
ACU_REDIRECT_URI=http://localhost:8080/oauth/callback

# --- Session cookie signing key (web UI) ---
# Any long random string. Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SESSION_SECRET=

# --- Destination ---
OUTPUT_URI=file:///data

# --- Destination credentials (only set for scheme you use) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_STORAGE_CONNECTION_STRING=
# GOOGLE_APPLICATION_CREDENTIALS=
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=

# --- Headless CLI mode ---
# The CLI (`attdown run --config ...`) reads its auth from config.yaml,
# typically OAuth Client Credentials with a service-account Connected App.
# None of the vars above are required for that path.
